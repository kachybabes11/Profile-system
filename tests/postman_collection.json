{
  "info": {
    "name": "Profile Intelligence System API",
    "description": "API test collection for Profile Intelligence System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://profile-system-production.up.railway.app",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "GitHub OAuth Login",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/auth/github",
          "host": ["{{base_url}}"],
          "path": ["auth", "github"]
        }
      }
    },
    {
      "name": "Get Current User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "X-API-Version",
            "value": "1",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/auth/me",
          "host": ["{{base_url}}"],
          "path": ["auth", "me"]
        }
      }
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-API-Version",
            "value": "1",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/auth/refresh",
          "host": ["{{base_url}}"],
          "path": ["auth", "refresh"]
        }
      }
    },
    {
      "name": "Get Profiles (Admin)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "X-API-Version",
            "value": "1",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/profiles?page=1&limit=10",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "Create Profile (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "X-API-Version",
            "value": "1",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/profiles",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles"]
        }
      }
    },
    {
      "name": "Search Profiles",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "X-API-Version",
            "value": "1",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/profiles/search?q=young%20females",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles", "search"],
          "query": [
            {
              "key": "q",
              "value": "young females"
            }
          ]
        }
      }
    },
    {
      "name": "Export Profiles CSV",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "X-API-Version",
            "value": "1",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/profiles/export",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles", "export"]
        }
      }
    },
    {
      "name": "Upload CSV (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "X-API-Version",
            "value": "1",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "file",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/api/profiles/upload/csv",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles", "upload", "csv"]
        }
      }
    },
    {
      "name": "Get Single Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "X-API-Version",
            "value": "1",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/profiles/{{profile_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles", "{{profile_id}}"]
        }
      }
    },
    {
      "name": "Delete Profile (Admin)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "type": "text"
          },
          {
            "key": "X-API-Version",
            "value": "1",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/profiles/{{profile_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "profiles", "{{profile_id}}"]
        }
      }
    }
  ]
}</content>
